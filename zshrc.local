# Antigen plugin manager.
#
# NOTE: antigen compiles the bundle list below into ~/.antigen/init.zsh and
# reuses that cache — editing this file does NOT auto-invalidate it. After
# adding/removing any `antigen bundle`, run `antigen reset` once and restart the
# shell, otherwise the stale cache keeps loading the old bundles.
source /usr/share/zsh-antigen/antigen.zsh

# Stop oh-my-zsh from rebinding ZLE editing widgets. omz's core lib/misc.zsh
# runs `zle -N self-insert url-quote-magic`, which overwrites the
# fast-syntax-highlighting widget wrapper that dotfriedrice installed earlier
# and silently kills syntax highlighting as you type (F-Sy-H here highlights by
# wrapping widgets, with no redraw-hook fallback). Disabling the magic functions
# leaves self-insert / bracketed-paste wrapped by the highlighter, so we don't
# need to re-source it. Trade-off: no url-quote-magic / bracketed-paste-magic
# (auto-escaping URLs etc.) — dotfriedrice doesn't use them anyway.
DISABLE_MAGIC_FUNCTIONS=true

# oh-my-zsh + plugins.
#
# IMPORTANT: do NOT load a syntax highlighter, autosuggestions, a theme, or
# vi-mode here. dotfriedrice's ~/.config/zsh/.zshrc already provides
# fast-syntax-highlighting, zsh-autosuggestions, zsh-vi-mode, and its own prompt
# BEFORE this file is sourced. A second highlighter
# (zsh-users/zsh-syntax-highlighting) makes the two fight over ZLE's
# region_highlight and kills highlighting entirely.
antigen use oh-my-zsh
antigen bundle git
antigen bundle tmux
antigen bundle z
antigen bundle pip
antigen bundle lein
antigen bundle command-not-found

# External plugins (additive only — nothing that re-wraps ZLE editing widgets)
antigen bundle MichaelAquilina/zsh-you-should-use

# Apply
antigen apply

# Custom aliases
alias claude-yolo="claude --dangerously-skip-permissions --model 'opus[1m]' --effort xhigh"

# hotdog (security_agent / chatbot-cli dev workflow)
alias hotdog-clirun-raw='cd ~/dd/dd-source && ~/dd/dd-source/domains/chatbot/scripts/clirun -- security_agent'
alias hotdog-clirun-slow='cd ~/dd/dd-source && ~/dd/dd-source/domains/chatbot/scripts/clirun -l -d ${USER//./} -- security_agent'
alias hotdog-clirun='cd ~/dd/dd-source && ~/dd/dd-source/domains/chatbot/scripts/clirun -l -d ${USER//./}-fast-dev -- security_agent'
alias hotdog-deploy-raw='cd ~/dd/dd-source && ~/dd/dd-source/domains/chatbot/dev/hotdog-deploy'
alias hotdog-deploy-slow='cd ~/dd/dd-source && ~/dd/dd-source/domains/chatbot/dev/hotdog-deploy chatbot-cli ${USER//./}'
alias hotdog-deploy='cd ~/dd/dd-source && ~/dd/dd-source/domains/chatbot/dev/hotdog-deploy chatbot-cli ${USER//./} --legacy_fast --debug'
alias hotdog-update-raw='cd ~/dd/dd-source && ~/dd/dd-source/domains/chatbot/dev/hotdog-update'
alias hotdog-update-slow='cd ~/dd/dd-source && ~/dd/dd-source/domains/chatbot/dev/hotdog-update chatbot-cli ${USER//./}'
alias hotdog-update='cd ~/dd/dd-source && ~/dd/dd-source/domains/chatbot/dev/hotdog-update chatbot-cli ${USER//./} --sec-agent --debug'
alias hotdog-bash-slow='kubectl exec -it deployments/chatbot-cli-hotdog-${USER//./} -n chatbot -c chatbot-cli -- bash'
alias hotdog-bash='kubectl exec -it deployments/chatbot-cli-hotdog-${USER//./}-fast-dev -n chatbot -c chatbot-cli -- bash'
alias hotdog-delete-slow='kubectl delete deployment --namespace chatbot chatbot-cli-hotdog-${USER//./}'
alias hotdog-delete='kubectl delete deployment --namespace chatbot chatbot-cli-hotdog-${USER//./}-fast-dev'
alias hotdog-logs='open "https://app.datadoghq.com/logs?query=service%3Achatbot-cli%20kube_deployment%3Achatbot-cli-hotdog-${USER//./}-fast-dev"'
alias hotdog-shell='kubectl -n chatbot exec -it deployment/chatbot-cli-hotdog-${USER//./}-fast-dev -- bash'
alias hotdog-check-git-sha='cd ~/dd/dd-source && ~/dd/dd-source/domains/chatbot/dev/hotdog-check-git-sha chatbot-cli ${USER//./}-fast-dev'
alias hotdog-pods='open "https://app.datadoghq.com/orchestration/explorer/pod?query=kube_deployment%3Achatbot-cli-hotdog-${USER//./}*"'
alias hotdog-k-logs='kubectl logs -n chatbot deployment/chatbot-cli-hotdog-${USER//./}-fast-dev --tail=100'
alias hotdog-k-pods='kubectl get pods --namespace chatbot -l app=chatbot-cli-hotdog-${USER//./}-fast-dev'
