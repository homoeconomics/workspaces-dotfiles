{
  "apiKeyHelper": "workspace_secret ANTHROPIC_APIKEY1",
  "env": {
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(tree:*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(file:*)",
      "Bash(diff:*)",
      "Bash(jq:*)",
      "Bash(shellcheck:*)",
      "Bash(grep:*)",
      "Bash(tr:*)",
      "Bash(lsof:*)",
      "Bash(head:*)",
      "Bash(xxd:*)",
      "Bash(git grep:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git remote:*)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-files:*)",
      "Bash(git stash list:*)",
      "Bash(git check-ignore:*)",
      "Bash(git show-ref:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh repo view:*)",
      "Bash(gh pr checks:*)"
    ],
    "defaultMode": "plan"
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "dd@datadog-claude-plugins": true,
    "odp-sql@datadog-claude-plugins": true,
    "code-simplifier@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "feature@datadog-claude-plugins": true,
    "superpowers@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "datadog": {
      "source": {
        "source": "github",
        "repo": "DataDog/claude-marketplace"
      }
    }
  },
  "forceLoginMethod": "console",
  "effortLevel": "high",
  "model": "opus"
}
